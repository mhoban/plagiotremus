begin mrbayes;

  outgroup Oan-AMS266-08;
	charset Subset1 = 3-393\3 1-391\3;
	charset Subset2 = 2-392\3;

	partition PartitionFinder = 2:Subset1, Subset2;
	set partition=PartitionFinder;

	lset applyto=(1) nst=6 rates=propinv;
	lset applyto=(2) nst=6 rates=gamma;

	prset applyto=(all) ratepr=variable;
	unlink statefreq=(all) revmat=(all) shape=(all) pinvar=(all) tratio=(all);

  mcmc append=no ngen=20000000 samplefreq=1000 printfreq=1000 temp=0.2 nchains=12 nruns=3 checkfreq=1000;
  sumt burnin=4000000;
  sump burnin=4000000;

end;
