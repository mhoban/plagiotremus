begin mrbayes;

  outgroup Oan-AMS266-08;
  outgroup Oan-FNZ657-06;
  outgroup Oan-FNZ661-06;
  outgroup Oan-AMS462-08;
  outgroup Oan-ANGBF32284-19;

  charset Subset1 = 1-535\3;
  charset Subset2 = 2-533\3;
  charset Subset3 = 3-534\3;

  partition PartitionFinder = 3:Subset1, Subset2, Subset3;
  set partition=PartitionFinder;

  lset applyto=(1) nst=6 rates=gamma;
  lset applyto=(2) nst=6 rates=invgamma;
  prset applyto=(2) statefreqpr=fixed(equal);
  lset applyto=(3) nst=2 rates=propinv;
  prset applyto=(all) ratepr=variable;
  unlink statefreq=(all) revmat=(all) shape=(all) pinvar=(all) tratio=(all);

  mcmc append=yes ngen=20000000 samplefreq=1000 printfreq=1000 temp=0.2 nchains=12 nruns=3;
  sumt burnin=4000000;
  sump burnin=4000000;

end;

