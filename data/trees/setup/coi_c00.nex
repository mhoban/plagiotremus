begin mrbayes;

	charset Subset1 = 1-697\3;
	charset Subset2 = 2-698\3;
	charset Subset3 = 3-696\3;

	partition PartitionFinder = 3:Subset1, Subset2, Subset3;
	set partition=PartitionFinder;

	lset applyto=(1) nst=6 rates=gamma;
	lset applyto=(2) nst=6 rates=invgamma;
	lset applyto=(3) nst=6 rates=propinv;

	prset applyto=(all) ratepr=variable;
	unlink statefreq=(all) revmat=(all) shape=(all) pinvar=(all) tratio=(all);

  mcmc append=no ngen=20000000 samplefreq=1000 printfreq=1000 temp=0.2 nchains=6 nruns=3 checkfreq=1000;
  sumt burnin=4000000;
  sump burnin=4000000;

end;
